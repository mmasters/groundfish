# Copy to .env and adjust. All variables are optional; defaults shown below.

# --- Engine ---
# Path to the native Stockfish binary. In Docker this is /usr/local/bin/stockfish.
# For local (non-Docker) dev on macOS with `brew install stockfish`, set it to the
# brew path, e.g. /opt/homebrew/bin/stockfish (Apple Silicon) or /usr/local/bin/stockfish.
STOCKFISH_ENGINE_PATH=/usr/local/bin/stockfish
# Number of Stockfish subprocesses in the pool (defaults to min(cpu, 4)).
#STOCKFISH_ENGINE_POOL_SIZE=4
# Per-engine UCI Hash table size (MB).
STOCKFISH_ENGINE_HASH_MB=64

# --- Search limits (movetime in milliseconds; also act as DoS guards) ---
STOCKFISH_DEFAULT_MOVETIME_MS=600
STOCKFISH_MIN_MOVETIME_MS=50
STOCKFISH_MAX_MOVETIME_MS=2000

# --- Timeouts (seconds) ---
STOCKFISH_ENGINE_TIMEOUT_MARGIN_S=2.0
STOCKFISH_POOL_ACQUIRE_TIMEOUT_S=5.0
STOCKFISH_ENGINE_START_TIMEOUT_S=20.0

# --- Logging ---
STOCKFISH_LOG_FILE=./logs/groundfish.log
STOCKFISH_LOG_LEVEL=INFO
STOCKFISH_LOG_TO_STDOUT=true
